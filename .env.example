# =============================================================
# Label Aarfa — environment variables
# =============================================================
# Copy this file to `.env.local` for local dev:  cp .env.example .env.local
# In production, set these in the Vercel dashboard (Project Settings → Environment Variables).
#
# Variables prefixed with `VITE_` are INLINED into the client bundle at build time.
# Only put values here that are safe for the public to read.

# ------- Supabase -------
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY

# SERVER ONLY — never prefix with VITE_, never commit a real value.
# Used by api/* functions to bypass RLS and write orders/newsletter/contact rows.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# ------- Razorpay -------
# Key ID is public (it ships to the browser to open Razorpay Checkout).
VITE_RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXX

# SERVER ONLY.
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=YOUR_TEST_SECRET

# Webhook signing secret — set this in Razorpay Dashboard → Webhooks
RAZORPAY_WEBHOOK_SECRET=YOUR_WEBHOOK_SECRET

# ------- Resend (transactional email) -------
RESEND_API_KEY=re_XXXXXXXXXXXXXXXX

# Sending identity. Must match a verified domain or sender in Resend.
# For initial dev you can use onboarding@resend.dev (Resend's shared sender).
FROM_EMAIL="Label Aarfa <care@labelaarfa.com>"
ADMIN_EMAIL=care@labelaarfa.com
