{
  "rewrites": [
    { "source": "/products/:slug", "destination": "/index.html" },
    { "source": "/collections/:slug", "destination": "/index.html" },
    { "source": "/info/:slug", "destination": "/index.html" },
    { "source": "/about", "destination": "/index.html" },
    { "source": "/contact", "destination": "/index.html" },
    { "source": "/wishlist", "destination": "/index.html" },
    { "source": "/orders", "destination": "/index.html" },
    { "source": "/checkout", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/:path*",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/images/:path*",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
